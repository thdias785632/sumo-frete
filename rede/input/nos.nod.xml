<?xml version="1.0" encoding="UTF-8"?>
<!-- Nos (nodes) da rede de frete: 3 rotas distintas A..B -->
<nodes>
    <!-- A = Centro de Distribuicao (Origem) -->
    <node id="A"  x="0.0"      y="0.0"      type="priority"/>

    <!-- N1 = Intersecao urbana COM semaforo (Rota 1 - caminho reto) -->
    <node id="N1" x="2500.0"   y="0.0"      type="traffic_light"/>

    <!-- N2 = Intersecao arterial SEM semaforo (Rota 2 - desvio moderado ao sul) -->
    <node id="N2" x="2500.0"   y="-2450.0"  type="priority"/>

    <!-- N3 = Intersecao rodoviaria SEM semaforo (Rota 3 - desvio grande ao sul) -->
    <node id="N3" x="2500.0"   y="-3969.0"  type="priority"/>

    <!-- B = Cliente (Destino) -->
    <node id="B"  x="5000.0"   y="0.0"      type="priority"/>
</nodes>
